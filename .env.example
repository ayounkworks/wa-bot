# Salin file ini menjadi .env dan isi nilainya
# Di Railway, isi nilai ini di tab "Variables"

# Nomor atasan (tanpa + atau spasi, format internasional)
# Contoh: 6281234567890
BOSS_NUMBER=628xxxxxxxxxx

# Nama kamu persis seperti yang ingin ditambahkan ke list
MY_NAME=Ayounk

# Nama grup WhatsApp (harus PERSIS SAMA dengan nama grup, termasuk huruf besar/kecil)
TARGET_GROUP=Grup Kerja Malam

# Keywords yang memicu bot (pisah dengan koma, tanpa spasi)
KEYWORDS=list kerja,kerja malam,list malam,lembur

# Delay sebelum kirim (millisecond). Default: 2000 - 5000 (2-5 detik)
DELAY_MIN=2000
DELAY_MAX=5000

# Sensitivitas deteksi duplikat (0.0 - 1.0)
# 0.75 = toleran 1-2 karakter typo. Turunkan jika terlalu sensitif.
FUZZY_THRESHOLD=0.75
